---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import HeroImageDark from "~/assets/Dev-Docs-Header-Illustration-Dark-Mode-cropped.svg";
import HeroImageLight from "~/assets/Dev-Docs-Header-Illustration-Light-Mode-cropped.svg";

import { Tabs, TabItem } from "@astrojs/starlight/components";
import Render from "~/components/Render.astro";

const frontmatter = {
	title: "Welcome to Cloudflare",
	description:
		"Explore guides and tutorials to start building on Cloudflare's platform",
	template: "splash",
	hero: {
		title: "Welcome to Cloudflare",
		tagline:
			"Explore guides and tutorials to start building on Cloudflare's platform",
		image: {
			dark: HeroImageDark,
			light: HeroImageLight,
		},
	},
} as const;

const cards = [
	{
		label: "Fundamentals",
		href: "/fundamentals/",
		description: "How Cloudflare works and how to get started.",
	},
	{
		label: "Docs directory",
		href: "/products/",
		description: "How to use specific Cloudflare products.",
	},
	{
		label: "Learning paths",
		href: "/learning-paths/",
		description: "Step-by-step walkthroughs on a variety of concepts.",
	},
	{
		label: "Reference architectures",
		href: "/reference-architectures/",
		description: "How our products are designed and architected.",
	},
];

const footer = [
	{
		heading: "Community",
		description:
			"Share ideas, answers, code and compare notes with the Cloudflare community",
		links: [
			{
				label: "Discord",
				href: "https://discord.gg/cloudflaredev",
			},
			{
				label: "Twitter",
				href: "https://twitter.com/cloudflaredev",
			},
			{
				label: "Community forum",
				href: "https://community.cloudflare.com/",
			},
		],
	},
	{
		heading: "Open Source",
		description:
			"Cloudflare contributes to the open-source ecosystem in a variety of ways, including:",
		links: [
			{
				label: "GitHub projects",
				href: "https://github.com/cloudflare/",
			},
			{
				label: "Sponsorship projects",
				href: "/sponsorships/",
			},
			{
				label: "Style guide",
				href: "/style-guide/",
			},
		],
	},
	{
		label: "Blog",
		description:
			"Get the latest news on Cloudflare products, technologies, and culture.",
		links: [
			{
				label: "Read the blog",
				href: "https://blog.cloudflare.com/",
			},
		],
	},
];
---

<StarlightPage frontmatter={frontmatter}>
	<div class="grid grid-cols-4 gap-4">
		{
			cards.map((card) => (
				<a
					href={card.href}
					class="rounded-md border border-solid border-gray-200 p-6 !text-inherit no-underline hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800"
				>
					<p class="!mt-3 font-semibold">{card.label}</p>
					<div class="leading-2 !mt-1 text-sm">{card.description}</div>
				</a>
			))
		}
	</div>
	<div class="flex flex-col items-center justify-center p-16">
		<h2>Explore Cloudflare offerings</h2>
	</div>
	<div class="flex flex-col items-center justify-center p-16">
		<h2>Get started</h2>
	</div>
	<div class="flex flex-col p-16">
		<div>
			<h2>Build with Cloudflare</h2>
		</div>
		<div>
			<Tabs>
				<TabItem label="Return HTML">
					<Render file="return-html-example-js" product="workers" />
				</TabItem>
				<TabItem label="Return JSON">
					<Render file="return-json-example-js" product="workers" />
				</TabItem>
				<TabItem label="Fetch HTML">
					<Render file="fetch-html-example-js" product="workers" />
				</TabItem>
				<TabItem label="Redirect">
					<Render file="redirect-example-js" product="workers" />
				</TabItem>
				<TabItem label="Respond with another site">
					<Render file="respond-another-site-example-js" product="workers" />
				</TabItem>
			</Tabs>
		</div>
	</div>
	<div class="flex flex-col items-center justify-center p-16">
		<h2>Documentation changelog</h2>
	</div>
	<div class="flex items-center justify-center gap-8 p-16">
		{footer.map((group) => <div></div>)}
	</div>
</StarlightPage>
